# Copie para .env e preencha os valores reais (nunca commite .env)

# Ambiente
ENV=development

# Caminhos de dados (use caminhos absolutos ou relativos ao projeto)
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_OUTPUT_PATH=data/outputs

